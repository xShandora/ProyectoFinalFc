{% extends 'base.html.twig' %}

{% block title %}{{ flor.name }} - Detalles{% endblock %}

{% block body %}
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        {# Botón para volver atrás #}
        <a href="{{ path('app_catalog') }}" style="text-decoration: none; color: #3498db; font-size: 16px;">
            &larr; Volver al catálogo
        </a>

        <h1 style="margin-top: 20px; font-size: 32px;">{{ flor.name }}</h1>

        {% if flor.image %}
            <img src="/uploads/flowers/{{ flor.image }}" alt="{{ flor.name }}" style="width: 100%; border-radius: 8px; margin-bottom: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
        {% endif %}

        <p style="font-size: 18px; line-height: 1.6;">{{ flor.description }}</p>

        <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin-top: 20px; border: 1px solid #eee;">
            <p style="margin: 0; font-size: 22px; color: #27ae60;"><strong>Precio: {{ flor.price }} €</strong></p>
            <p style="margin: 5px 0 0 0; color: #7f8c8d;">Stock disponible: {{ flor.stock }} unidades</p>
        </div>

        {# Este botón es de adorno por ahora, ¡pero da el pego total! #}
        <div style="margin-top: 30px;">
            <button style="background-color: #2c3e50; color: white; padding: 12px 25px; border: none; border-radius: 5px; font-size: 18px; cursor: pointer; width: 100%;">
                🛒 Añadir al carrito
            </button>
        </div>
    </div>
{% endblock %}