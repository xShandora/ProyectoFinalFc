{% extends 'base.html.twig' %}

{% block title %}{{ flor.name }} - Lycoris Radiata{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto mt-4 mb-16">
    
    <a href="{{ path('app_catalog') }}" class="inline-flex items-center gap-2 text-gray-500 hover:text-[#FF6F94] transition-colors mb-6 font-medium">
        <span class="text-xl">←</span> Volver al catálogo
    </a>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col md:flex-row">
        
        <div class="md:w-1/2 relative bg-gray-50 h-80 md:h-auto min-h-[400px] lg:min-h-[500px]">
            {% if flor.image %}
                <img src="/uploads/flowers/{{ flor.image }}" alt="{{ flor.name }}" class="absolute inset-0 w-full h-full object-cover">
            {% else %}
                <div class="absolute inset-0 w-full h-full flex items-center justify-center text-gray-300">
                    <span class="text-8xl">🌸</span>
                </div>
            {% endif %}
            
            {% if is_granted('ROLE_ADMIN') %}
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-lg text-sm font-bold text-gray-600 shadow-sm">
                    Stock: {{ flor.stock }} ud.
                </div>
            {% endif %}
        </div>

        <div class="md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
            
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">{{ flor.name }}</h1>
            
            <div class="text-3xl font-bold mb-8" style="color: #FF6F94;">
                {{ flor.price|number_format(2, ',', '.') }} €
            </div>

            <div class="text-gray-600 leading-relaxed mb-10 flex-1">
                <h3 class="text-sm font-bold text-gray-800 uppercase tracking-wider mb-3">Descripción</h3>
                <p>{{ flor.description }}</p>
            </div>

            <form action="{{ path('app_cart_add', {'id': flor.id}) }}" method="POST" class="flex flex-col sm:flex-row gap-4 mt-auto">
                
                {# ESTA ES LA SEÑAL OCULTA #}
                <input type="hidden" name="redireccion" value="catalogo">
                
                <div class="flex items-center justify-between rounded-xl h-14 w-full sm:w-36 bg-gray-100 border border-gray-200 shadow-inner">
                    <button type="button" onclick="let input = this.nextElementSibling; if(input.value > 1) input.value--;" class="w-12 h-full text-gray-500 hover:text-[#FF6F94] transition-colors text-2xl font-bold rounded-l-xl focus:outline-none">-</button>
                    <input type="number" name="cantidad" value="1" min="1" class="w-12 text-center font-bold text-gray-800 border-none focus:ring-0 p-0 bg-transparent [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
                    <button type="button" onclick="let input = this.previousElementSibling; input.value++;" class="w-12 h-full text-gray-500 hover:text-[#FF6F94] transition-colors text-xl font-bold rounded-r-xl focus:outline-none">+</button>
                </div>

                <button type="submit" class="flex-1 text-center text-white font-bold py-4 px-6 rounded-xl shadow-[0_8px_20px_rgba(255,111,148,0.3)] transition-transform transform hover:-translate-y-0.5 text-lg" style="background-color: #FF6F94;">
                    🛒 Añadir al carrito
                </button>
            </form>

        </div>
    </div>
</div>
{% endblock %}