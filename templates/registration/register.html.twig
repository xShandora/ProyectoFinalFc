{% extends 'base.html.twig' %}

{% block title %}Registro - Lycoris Radiata{% endblock %}

{% block body %}
<div class="relative flex items-center justify-center min-h-[calc(100vh-8rem)] py-12 px-4" 
     style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); margin-top: -2rem; margin-bottom: -2rem;">
    
    <div class="absolute inset-0 z-0 bg-cover bg-center" style="background-image: url('https://www.pixelstalk.net/wp-content/uploads/2025/05/A-gentle-splash-of-pink-watercolor-forming-floral-patterns-perfect-for-pink-theme-computer-background-lovers.png?utm_source=Pinterest&utm_medium=organic');"></div>
    <div class="absolute inset-0 z-0 backdrop-blur-sm bg-white/50"></div>

    <div class="relative z-10 w-full max-w-md bg-white/95 backdrop-blur-sm rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] p-8 border border-white/60">
        
        <div class="text-center mb-8">
            <h1 class="text-5xl tracking-wide" style="color: #FF6F94; font-family: 'Great Vibes', cursive;">Registrate</h1>
        </div>

        <div class="text-red-500 text-sm mb-4 text-center">
            {{ form_errors(registrationForm) }}
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5'}}) }}
            
            <div>
                {{ form_label(registrationForm.nombre, 'Nombre', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(registrationForm.nombre, {'attr': {'class': 'w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.nombre) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.apellidos, 'Apellidos', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(registrationForm.apellidos, {'attr': {'class': 'w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.apellidos) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.email) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword, 'Contraseña', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
            </div>

            <div class="flex items-center mt-2">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'h-4 w-4 rounded border-gray-300 text-[#FF6F94] focus:ring-[#FF6F94]'}}) }}
                {{ form_label(registrationForm.agreeTerms, 'Acepto los términos y condiciones', {'label_attr': {'class': 'ml-2 block text-sm text-gray-700 cursor-pointer'}}) }}
            </div>
            <div class="text-red-500 text-xs">{{ form_errors(registrationForm.agreeTerms) }}</div>

            <button type="submit" class="w-full text-white font-medium py-3 px-4 rounded-lg shadow-[0_8px_20px_rgba(255,111,148,0.3)] transition-transform transform hover:-translate-y-0.5 mt-8" style="background-color: #FF6F94;">
                Registrarse
            </button>
            
        {{ form_end(registrationForm) }}
        
        <div class="mt-8 text-center">
            <a href="{{ path('app_login') }}" class="text-sm font-medium transition-colors hover:underline" style="color: #5a8a31;">
                ¿Ya tienes cuenta? Inicia sesión
            </a>
        </div>

    </div>
</div>
{% endblock %}