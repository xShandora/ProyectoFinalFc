{% extends 'base.html.twig' %}

{% block title %}Iniciar sesión - Floristería{% endblock %}

{% block body %}
<div class="relative flex items-center justify-center min-h-[calc(100vh-8rem)] py-12 px-4" 
     style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); margin-top: -2rem; margin-bottom: -2rem;">
    
    <div class="absolute inset-0 z-0 bg-cover bg-center" style="background-image: url('https://www.pixelstalk.net/wp-content/uploads/2025/05/A-gentle-splash-of-pink-watercolor-forming-floral-patterns-perfect-for-pink-theme-computer-background-lovers.png?utm_source=Pinterest&utm_medium=organic');"></div>
    <div class="absolute inset-0 z-0 backdrop-blur-sm bg-white/50"></div>

    <div class="relative z-10 w-full max-w-md bg-white/95 backdrop-blur-sm rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] p-8 border border-white/60">
        
        <div class="text-center mb-8">
            <h1 class="text-5xl tracking-wide" style="color: #FF6F94; font-family: 'Great Vibes', cursive;">Iniciar sesión</h1>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mb-4 p-3 rounded-lg bg-green-50 text-green-700 text-sm text-center font-medium border border-green-200">
                {{ message }}
            </div>
        {% endfor %}
        
        {% if error %}
            <div style="color: red; font-weight: bold; margin-bottom: 15px;">
                
            </div>
        {% endif %}

        {% if error %}
            <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-700 text-sm text-center font-medium border border-red-200">
                El correo o la contraseña son incorrectos.
            </div>
        {% endif %}

        {% if app.user %}
            <div class="mb-4 p-3 rounded-lg bg-blue-50 text-blue-700 text-sm text-center border border-blue-200">
                Has iniciado sesión como {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}" class="font-bold underline hover:text-blue-900">Cerrar sesión</a>
            </div>
        {% endif %}

        <form method="post" class="space-y-5">
            
            <div>
                <label for="inputEmail" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]" autocomplete="email" required autofocus>
            </div>

            <div>
                <label for="inputPassword" class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
                <input type="password" name="password" id="inputPassword" class="w-full px-4 py-2 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:outline-none transition-shadow focus:border-[#B6DA8F] focus:ring-[#B6DA8F]" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="w-full text-white font-medium py-3 px-4 rounded-lg shadow-[0_8px_20px_rgba(255,111,148,0.3)] transition-transform transform hover:-translate-y-0.5 mt-8" style="background-color: #FF6F94;" type="submit">
                Entrar
            </button>
            
        </form>
        
        <div class="mt-8 text-center">
            <a href="{{ path('app_register') }}" class="text-sm font-medium transition-colors hover:underline" style="color: #5a8a31;">
                ¿No tienes cuenta? Regístrate
            </a>
        </div>

    </div>
</div>
{% endblock %}