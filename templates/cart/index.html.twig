{% extends 'base.html.twig' %}

{% block title %}Tu Carrito - Lycoris Radiata{% endblock %}

{% block body %}
<div class="w-full px-4 md:px-6 mt-4 mb-16">

    <div class="flex flex-col sm:flex-row justify-between items-center mb-8 gap-4">
        <h1 class="text-4xl tracking-wide" style="color: #FF6F94; font-family: 'Great Vibes', cursive;">Tu cesta de la compra</h1>
        
        <a href="{{ path('app_catalog') }}" class="text-gray-500 hover:text-[#FF6F94] transition-colors font-medium flex items-center gap-2">
            <span class="text-xl">←</span> Seguir comprando
        </a>
    </div>

    <div class="flex flex-col lg:flex-row gap-6 items-start">

        {# CONTENEDOR IZQUIERDO: Lista de Productos #}
        <div class="w-full lg:w-2/3 bg-white rounded-3xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-6 border-b border-gray-100 pb-4">Artículos en tu carrito</h2>
            
            {% if elementos is defined and elementos|length > 0 %}
                <div class="divide-y divide-gray-100">
                    {% for item in elementos %}
                        <div class="py-4 flex items-center justify-between gap-3 sm:gap-4 first:pt-0 last:pb-0">
                            
                            {# Foto y Datos Básicos #}
                            <div class="flex items-center gap-3 flex-1 overflow-hidden">
                                {# Foto reducida a w-16 h-16 #}
                                <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-50 border border-gray-100 shrink-0">
                                    {% if item.flor.image %}
                                        <img src="/uploads/flowers/{{ item.flor.image }}" alt="{{ item.flor.name }}" class="w-full h-full object-cover">
                                    {% else %}
                                        <div class="w-full h-full flex items-center justify-center text-xl bg-gray-50 text-gray-300">🌸</div>
                                    {% endif %}
                                </div>
                                <div class="text-left truncate">
                                    <h3 class="font-bold text-gray-800 text-base truncate">{{ item.flor.name }}</h3>
                                    <p class="text-xs text-gray-400 mt-0.5">{{ item.flor.price|number_format(2, ',', '.') }} € / ud.</p>
                                </div>
                            </div>

                            {# Selector de Cantidad, Total y Borrar #}
                            <div class="flex items-center justify-end gap-3 sm:gap-6 shrink-0">
                                
                                {# Controles +- más bajitos y estrechos #}
                                <div class="flex items-center justify-between rounded-lg h-9 w-20 sm:w-24 bg-gray-100 border border-gray-200 shadow-inner">
                                    <a href="{{ path('app_cart_decrease', {'id': item.flor.id}) }}" class="w-7 sm:w-8 h-full flex items-center justify-center text-gray-500 hover:text-[#FF6F94] transition-colors text-lg font-bold focus:outline-none select-none">
                                        -
                                    </a>
                                    <span class="font-bold text-gray-800 text-xs sm:text-sm">{{ item.cantidad }}</span>
                                    <a href="{{ path('app_cart_add', {'id': item.flor.id}) }}" class="w-7 sm:w-8 h-full flex items-center justify-center text-gray-500 hover:text-[#FF6F94] transition-colors text-base font-bold focus:outline-none select-none">
                                        +
                                    </a>
                                </div>

                                {# Subtotal de la línea #}
                                <div class="text-right w-16 sm:min-w-[5rem]">
                                    <span class="font-bold text-gray-900 text-sm sm:text-base whitespace-nowrap">
                                        {{ (item.flor.price * item.cantidad)|number_format(2, ',', '.') }} €
                                    </span>
                                </div>

                                {# Botón Eliminar Fila (corregido el viewBox del svg) #}
                                <a href="{{ path('app_cart_remove', {'id': item.flor.id}) }}" class="text-gray-300 hover:text-red-500 transition-colors p-1" title="Eliminar del carrito">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </a>

                            </div>

                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="py-12 flex flex-col items-center justify-center border-2 border-dashed border-gray-100 rounded-2xl">
                    <span class="text-5xl mb-4">🛒</span>
                    <p class="text-gray-400 font-medium mb-4">Tu carrito está vacío</p>
                    <a href="{{ path('app_catalog') }}" class="text-sm font-bold px-4 py-2 rounded-xl text-white transition-transform transform hover:-translate-y-0.5" style="background-color: #FF6F94;">
                        Ir al catálogo
                    </a>
                </div>
            {% endif %}
        </div>

        <div class="w-full lg:w-1/3 bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-8">
            <h2 class="text-xl font-bold text-gray-800 mb-6 border-b border-gray-100 pb-4">Resumen del pedido</h2>
            
            {% if elementos is defined and elementos|length > 0 %}
                
                {% set totalCart = 0 %}
                {% for item in elementos %}
                    {% set totalCart = totalCart + (item.flor.price * item.cantidad) %}
                {% endfor %}

                <div class="space-y-4 text-gray-600 mb-6 text-sm sm:text-base">
                    <div class="flex justify-between">
                        <span>Subtotal</span>
                        <span>{{ totalCart|number_format(2, ',', '.') }} €</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Gastos de envío</span>
                        <span class="text-[#B6DA8F] font-bold">Gratis</span>
                    </div>
                </div>

                <div class="border-t border-gray-100 pt-4 mb-8">
                    <div class="flex justify-between items-center">
                        <span class="text-lg font-bold text-gray-800">Total</span>
                        <span class="text-3xl font-bold text-gray-900">{{ totalCart|number_format(2, ',', '.') }} €</span>
                    </div>
                    <p class="text-xs text-gray-400 mt-1 text-right">IVA incluido</p>
                </div>

                <div class="flex flex-col gap-3">
                    <button class="w-full text-center text-white font-bold py-4 px-6 rounded-xl shadow-[0_8px_20px_rgba(255,111,148,0.3)] transition-transform transform hover:-translate-y-0.5 text-lg" style="background-color: #FF6F94;">
                        Tramitar Pedido
                    </button>
                    
                    <a href="{{ path('app_cart_empty') }}" class="w-full text-center text-gray-500 hover:text-red-500 font-medium py-3 rounded-xl transition-colors text-sm border border-transparent hover:border-red-100 hover:bg-red-50">
                        Vaciar carrito
                    </a>
                </div>
                
            {% else %}
                <div class="text-center text-gray-400 py-8">
                    <p>Añade productos para ver el resumen.</p>
                </div>
            {% endif %}
        </div>

    </div>

</div>
{% endblock %}