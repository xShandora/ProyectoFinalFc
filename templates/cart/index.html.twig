{% extends 'base.html.twig' %}

{% block title %}Mi Carrito{% endblock %}

{% block body %}
    <h1>Tu Carrito de la Compra</h1>

    <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
        <a href="{{ path('app_catalog') }}" style="text-decoration: none; color: #3498db;">&larr; Seguir comprando</a>
        
        {# Botón para vaciar el carrito por completo #}
        {% if elementos|length > 0 %}
            <a href="{{ path('app_cart_empty') }}" style="background-color: #e74c3c; color: white; padding: 8px 12px; text-decoration: none; border-radius: 4px; font-size: 14px;">
                🗑️ Vaciar carrito
            </a>
        {% endif %}
    </div>

    {% if elementos|length > 0 %}
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="border-bottom: 2px solid #ccc;">
                    <th style="padding: 10px;">Producto</th>
                    <th style="padding: 10px;">Precio</th>
                    <th style="padding: 10px; text-align: center;">Cantidad</th>
                    <th style="padding: 10px;">Total</th>
                    <th style="padding: 10px; text-align: center;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                {% set totalCarrito = 0 %}
                
                {% for elemento in elementos %}
                    {% set totalProducto = elemento.flor.price * elemento.cantidad %}
                    {% set totalCarrito = totalCarrito + totalProducto %}
                    
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 10px;">{{ elemento.flor.name }}</td>
                        <td style="padding: 10px;">{{ elemento.flor.price }} €</td>
                        
                        {# Columna de Cantidad con botones de + y - #}
                        <td style="padding: 10px; text-align: center;">
                            <a href="{{ path('app_cart_decrease', {'id': elemento.flor.id}) }}" style="text-decoration: none; background: #eee; color: #333; padding: 2px 8px; border-radius: 3px; font-weight: bold; margin-right: 5px;">-</a>
                            <span style="font-size: 16px; font-weight: bold; min-width: 20px; display: inline-block;">{{ elemento.cantidad }}</span>
                            <a href="{{ path('app_cart_add', {'id': elemento.flor.id}) }}" style="text-decoration: none; background: #eee; color: #333; padding: 2px 6px; border-radius: 3px; font-weight: bold; margin-left: 5px;">+</a>
                        </td>
                        
                        <td style="padding: 10px;"><strong>{{ totalProducto }} €</strong></td>
                        
                        {# Botón para eliminar la fila completa #}
                        <td style="padding: 10px; text-align: center;">
                            <a href="{{ path('app_cart_remove', {'id': elemento.flor.id}) }}" style="color: #e74c3c; text-decoration: none; font-size: 14px;">
                                ❌ Eliminar
                            </a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

        <div style="margin-top: 20px; text-align: right; font-size: 20px;">
            <strong>Total del pedido: {{ totalCarrito }} €</strong>
        </div>
        
        <div style="margin-top: 30px; text-align: right;">
            <button style="background-color: #27ae60; color: white; padding: 10px 20px; border: none; border-radius: 5px; font-size: 16px; cursor: pointer;">
                Proceder al pago &rarr;
            </button>
        </div>
    {% else %}
        <p style="font-size: 18px; color: #7f8c8d;">Tu carrito está vacío ahora mismo.</p>
    {% endif %}
{% endblock %}