{% extends 'base.html.twig' %}

{% block title %}Mi Perfil - Lycoris Radiata{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto px-4 md:px-6 mt-8 mb-16">

    <h1 class="text-4xl tracking-wide text-gray-800 mb-8" style="font-family: 'Great Vibes', cursive;">Mi Cuenta</h1>

    <div class="flex flex-col md:flex-row gap-8">
        <aside class="w-full md:w-1/4">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-8">
                <div class="flex flex-col items-center mb-6 pb-6 border-b border-gray-100">
                    <div class="w-20 h-20 bg-[#FF6F94] text-white rounded-full flex items-center justify-center text-4xl font-bold shadow-sm mb-3">
                        {{ app.user.email|first|upper }}
                    </div>
                    <p class="text-gray-500 text-sm font-medium break-all text-center">{{ app.user.email }}</p>
                </div>

                <nav class="flex flex-col gap-2">
                    <a href="{{ path('app_profile') }}" class="px-4 py-3 rounded-xl bg-[#FF6F94]/10 text-[#FF6F94] font-bold flex items-center gap-3 transition-colors">
                        <span>📦</span> Mis Pedidos
                    </a>
                    
                    <a href="{{ path('app_profile_settings') }}" class="px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-gray-800 font-medium flex items-center gap-3 transition-colors">
                        <span>⚙️</span> Configuración
                    </a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="my-2 border-t border-gray-100"></div>
                        <a href="#" class="px-4 py-3 rounded-xl text-purple-600 hover:bg-purple-50 font-medium flex items-center gap-3 transition-colors">
                            <span>👑</span> Gestión Admin
                        </a>
                    {% endif %}
                </nav>

                {# Botón de Logout abajo del todo #}
                <div class="mt-8 pt-6 border-t border-gray-100">
                    <a href="{{ path('app_logout') }}" class="text-red-500 hover:text-red-600 text-sm font-medium flex items-center gap-2 transition-colors">
                        <span>🚪</span> Cerrar Sesión
                    </a>
                </div>
            </div>
        </aside>

        {# CONTENIDO PRINCIPAL (DERECHA) #}
        <main class="w-full md:w-3/4">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 md:p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b border-gray-100 pb-4">Historial de Pedidos</h2>

                {% if pedidos|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-gray-400 text-sm border-b border-gray-100">
                                    <th class="pb-3 font-medium">Referencia</th>
                                    <th class="pb-3 font-medium">Fecha</th>
                                    <th class="pb-3 font-medium">Estado</th>
                                    <th class="pb-3 font-medium text-right">Total</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-700">
                                {% for pedido in pedidos %}
                                    <tr class="border-b border-gray-50 last:border-0 hover:bg-gray-50 transition-colors">
                                        <td class="py-4 font-bold text-gray-800">{{ pedido.reference }}</td>
                                        <td class="py-4">{{ pedido.createdAt|date('d/m/Y H:i') }}</td>
                                        <td class="py-4">
                                            <span class="px-3 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700">
                                                {{ pedido.status }}
                                            </span>
                                        </td>
                                        <td class="py-4 text-right font-bold text-[#FF6F94]">
                                            {{ pedido.total|number_format(2, ',', '.') }} €
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-12">
                        <span class="text-5xl mb-4 block">🛒</span>
                        <p class="text-gray-400 font-medium mb-4">Aún no has realizado ningún pedido.</p>
                        <a href="{{ path('app_catalog') }}" class="text-[#FF6F94] font-bold hover:underline">
                            Ir de compras
                        </a>
                    </div>
                {% endif %}
            </div>
        </main>

    </div>
</div>
{% endblock %}