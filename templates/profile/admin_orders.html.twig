{% extends 'base.html.twig' %}

{% block title %}Panel de Administración - Lycoris Radiata{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 md:px-6 mt-8 mb-16">

    <h1 class="text-4xl tracking-wide text-gray-800 mb-8" style="font-family: 'Great Vibes', cursive;">Panel de Control</h1>

    <div class="flex flex-col md:flex-row gap-8">
        
        {# MENÚ LATERAL (SIDEBAR) #}
        <aside class="w-full md:w-1/4 shrink-0">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-8">
                
                <div class="flex flex-col items-center mb-6 pb-6 border-b border-gray-100">
                    <div class="w-20 h-20 bg-purple-600 text-white rounded-full flex items-center justify-center text-4xl font-bold shadow-sm mb-3">
                        👑
                    </div>
                    <p class="text-gray-500 text-sm font-medium break-all text-center">Administrador</p>
                </div>

                <nav class="flex flex-col gap-2">
                    <a href="{{ path('app_profile') }}" class="px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-gray-800 font-medium flex items-center gap-3 transition-colors">
                        <span>📦</span> Mis Pedidos
                    </a>
                    
                    <a href="{{ path('app_profile_settings') }}" class="px-4 py-3 rounded-xl text-gray-500 hover:bg-gray-50 hover:text-gray-800 font-medium flex items-center gap-3 transition-colors">
                        <span>⚙️</span> Configuración
                    </a>

                    <div class="my-2 border-t border-gray-100"></div>
                    {# Pestaña activa de Admin #}
                    <a href="{{ path('app_profile_admin_orders') }}" class="px-4 py-3 rounded-xl bg-purple-50 text-purple-700 font-bold flex items-center gap-3 transition-colors">
                        <span>👑</span> Gestión Pedidos
                    </a>
                </nav>

                <div class="mt-8 pt-6 border-t border-gray-100">
                    <a href="{{ path('app_logout') }}" class="text-red-500 hover:text-red-600 text-sm font-medium flex items-center gap-2 transition-colors">
                        <span>🚪</span> Cerrar Sesión
                    </a>
                </div>
            </div>
        </aside>

        {# CONTENIDO PRINCIPAL: Todos los pedidos de la tienda #}
        <main class="w-full md:w-3/4">
            <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 md:p-8">
                <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b border-gray-100 pb-4">Todos los Pedidos de la Tienda</h2>

                {% if pedidos|length > 0 %}
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[700px]">
                            <thead>
                                <tr class="text-gray-400 text-sm border-b border-gray-100">
                                    <th class="pb-3 font-medium">Ref. / Fecha</th>
                                    <th class="pb-3 font-medium">Cliente</th>
                                    <th class="pb-3 font-medium text-center">Estado</th>
                                    <th class="pb-3 font-medium text-right">Total</th>
                                    <th class="pb-3 font-medium text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="text-gray-700 text-sm">
                                {% for pedido in pedidos %}
                                    <tr class="border-b border-gray-50 last:border-0 hover:bg-gray-50 transition-colors">
                                        <td class="py-4">
                                            <div class="font-bold text-gray-800">{{ pedido.reference }}</div>
                                            <div class="text-xs text-gray-400">{{ pedido.createdAt|date('d/m/Y H:i') }}</div>
                                        </td>
                                        <td class="py-4">
                                            {{ pedido.user.email }}
                                        </td>
                                        <td class="py-4 text-center">
                                            {# Lógica de colores dinámicos #}
                                            {% set colorClass = 'bg-gray-100 text-gray-700' %}
                                            {% if pedido.status == 'PENDIENTE' %} {% set colorClass = 'bg-yellow-100 text-yellow-700' %}
                                            {% elseif pedido.status == 'ENVIADO' %} {% set colorClass = 'bg-blue-100 text-blue-700' %}
                                            {% elseif pedido.status == 'ENTREGADO' %} {% set colorClass = 'bg-green-100 text-green-700' %}
                                            {% elseif pedido.status == 'CANCELADO' %} {% set colorClass = 'bg-red-100 text-red-700' %}
                                            {% endif %}
                                            
                                            <span class="px-3 py-1.5 rounded-full text-xs font-bold {{ colorClass }}">
                                                {{ pedido.status }}
                                            </span>
                                        </td>
                                        <td class="py-4 text-right font-bold text-gray-800">
                                            {{ pedido.total|number_format(2, ',', '.') }} €
                                        </td>
                                        <td class="py-4">
                                            <div class="flex items-center justify-center gap-2">
                                                {% if pedido.status != 'ENVIADO' and pedido.status != 'ENTREGADO' and pedido.status != 'CANCELADO' %}
                                                    <a href="{{ path('app_profile_admin_update_status', {id: pedido.id, estado: 'ENVIADO'}) }}" class="w-8 h-8 flex items-center justify-center rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors" title="Marcar como Enviado">🚚</a>
                                                {% endif %}
                                                
                                                {% if pedido.status == 'ENVIADO' %}
                                                    <a href="{{ path('app_profile_admin_update_status', {id: pedido.id, estado: 'ENTREGADO'}) }}" class="w-8 h-8 flex items-center justify-center rounded-lg bg-green-50 text-green-600 hover:bg-green-100 transition-colors" title="Marcar como Entregado">✅</a>
                                                {% endif %}
                                                
                                                {% if pedido.status != 'CANCELADO' and pedido.status != 'ENTREGADO' %}
                                                    <a href="{{ path('app_profile_admin_update_status', {id: pedido.id, estado: 'CANCELADO'}) }}" class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-50 text-red-500 hover:bg-red-100 transition-colors" title="Cancelar">❌</a>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-12">
                        <span class="text-5xl mb-4 block">🏜️</span>
                        <p class="text-gray-400 font-medium">Aún no hay ningún pedido en la tienda.</p>
                    </div>
                {% endif %}
            </div>
        </main>

    </div>
</div>
{% endblock %}